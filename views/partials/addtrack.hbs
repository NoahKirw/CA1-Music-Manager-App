<form class="ui stacked segment form" action="/album/{{id}}/addsong" method="POST">
  <div class="three fields">
    <div class="field">
      <label>Title</label>
      <input type="text" name="name" autofocus required title = "Please include a valid Title"
	  placeholder="Title">
    </div>
    <div class="field">
      <label>Artist</label>
      <input type="text" name="artist" required title = "Please include a valid Artist"
	  placeholder="Artist"  >
    </div>
    <div class="field">
      <label>Duration</label>
      <input type="text" name="duration" placeholder="Duration (e.g. 3:45)">
    </div>
  </div>
  <button class="ui blue submit button">Add Track</button>
</form>
